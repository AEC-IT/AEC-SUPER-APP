# AEC Cinemas – CineFlow Intelligence ERP
# Environment Configuration
# ---------------------------------------------------
# NEON POSTGRESQL (Cloud) – Replace with your Neon connection details
# Get from: https://console.neon.tech → Your Project → Connection Details

DATABASE_URL=postgresql://neondb_owner:YOUR_NEON_PASSWORD@ep-YOUR-ENDPOINT.us-east-2.aws.neon.tech/neondb?sslmode=require

# OR fill in individual fields:
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=YOUR_NEON_PASSWORD
DB_HOST=ep-YOUR-ENDPOINT.us-east-2.aws.neon.tech
DB_PORT=5432
DB_SSLMODE=require

# Django
SECRET_KEY=aec-cinemas-production-secret-key-CHANGE-THIS
DEBUG=True

# Allowed hosts (comma-separated, no spaces)
# In production: ALLOWED_HOSTS=myapp.com,www.myapp.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Redis (Celery) – Optional
REDIS_URL=redis://localhost:6379/0

# ── Cloudinary (File Storage) ────────────────────────────────────────────────
# Get from: https://console.cloudinary.com → Dashboard
# Leave blank in local dev to use filesystem storage.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Brevo (Transactional Email) ───────────────────────────────────────────────
# Get from: https://app.brevo.com → SMTP & API → API Keys
# Leave blank in local dev to print emails to the console.
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=noreply@aeccinemas.com
BREVO_SENDER_NAME=AEC Cinemas

